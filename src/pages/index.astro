---
import Layout from '../layouts/Layout.astro';
---
<Layout>
  <a class="hero-link" href="/info">
    <main class="hero">
      <p class="hero-title">
        <span>PRIMA</span>
        <span>THE</span>
        <span>BOOK</span>
      </p>
    </main>
  </a>
</Layout>

<style>
  @font-face {
    font-family: "Styrene A LC Medium";
    src: url("/Styrene%20A%20LC%20Medium.ttf") format("truetype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  .hero-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .hero {
    min-height: calc(100svh - 16px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6vh 6vw;
    box-sizing: border-box;
    opacity: 0;
    animation: fade-in 900ms ease-out forwards;
  }

  .hero-title {
    margin: 0;
    font-family: "Styrene A LC Medium", "Aller Rg", ui-sans-serif, system-ui,
      -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans",
      "Liberation Sans", sans-serif;
    font-size: clamp(2.6rem, 11vw, 8.6rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: #fff;
    text-align: center;
  }

  .hero-title span {
    display: block;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 700px) {
    .hero {
      padding: 10vh 8vw 12vh;
    }

    .hero-title {
      font-size: clamp(2.2rem, 12vw, 6.2rem);
      line-height: 1.05;
    }
  }
</style>
