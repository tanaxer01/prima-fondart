---
import videoSrc from "../assets/video.mp4";
import mincapLogo from "../assets/mincap_logo.png";
---
<div class="video-wrap">
  <video
    class="hero-video"
    autoplay
    muted
    playsinline
    loop
  >
    <source src={videoSrc} type="video/mp4">
  </video>
  <div class="video-row">
    <span class="row-text row-left">PRIMA</span>
    <span class="row-text row-center">Formatos de representación en la arquitectura chilena</span>
    <img class="row-logo" src={mincapLogo.src} alt="Mincap logo" />
  </div>
</div>

<style>
  .video-wrap {
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
  }

  .hero-video {
    width: 50%;
    height: auto;
    max-height: 80vh;
    display: block;
    object-fit: contain;
  }

  .video-row {
    width: 80%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    color: #fff;
    font-size: 0.95rem;
    letter-spacing: 0.08em;
    text-transform: none;
  }

  .row-text {
    white-space: nowrap;
  }

  .row-left {
    flex: 0 0 auto;
  }

  .row-center {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    max-width: 60%;
  }

  .row-logo {
    height: 80px;
    width: auto;
    display: block;
    object-fit: contain;
    flex: 0 0 auto;
  }

  @media (max-width: 700px) {
    .hero-video,
    .video-row {
      width: 92%;
    }

    .video-row {
      font-size: 0.85rem;
      letter-spacing: 0.06em;
    }

    .row-logo {
      height: 64px;
    }
  }
</style>
