---
import videoSrc from "../assets/video.mp4";
import mincapLogo from "../assets/mincap_logo.png";
---
<div class="video-web">
  <video
    class="hero-video"
    autoplay
    muted
    playsinline
    loop
    preload="auto"
    onloadeddata="this.classList.add('is-ready')"
  >
    <source src={videoSrc} type="video/mp4">
  </video>
  <div class="info-row">
    <span class="row-left">PRIMA</span>
    <span class="row-center">Formatos de representación en la arquitectura chilena</span>
    <img class="row-logo" src={mincapLogo.src} alt="Mincap logo" />
  </div>
</div>

<style>
  .video-web {
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 24px;
    padding: 6vh 0;
    box-sizing: border-box;
  }

  .hero-video {
    width: 70%;
    height: auto;
    max-height: 70vh;
    display: block;
    object-fit: contain;
    opacity: 0;
    transition: opacity 240ms ease-out;
    background: #000;
    margin: 0 auto;
  }

  .hero-video.is-ready {
    opacity: 1;
  }

  .info-row {
    width: 80%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    color: #fff;
    font-size: 0.95rem;
    letter-spacing: 0.08em;
    min-height: 80px;
  }

  .row-left {
    white-space: nowrap;
  }

  .row-center {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    max-width: 52%;
    white-space: normal;
    padding: 0 12px;
  }

  .row-logo {
    height: 80px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  @media (max-width: 900px) {
    .video-web {
      display: none;
    }
  }
</style>
