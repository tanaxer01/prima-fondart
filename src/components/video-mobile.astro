---
import videoSrc from "../assets/video.mp4";
import mincapLogo from "../assets/mincap_logo.png";
---
<div class="video-mobile">
  <div class="mobile-top">
    <span class="row-title">PRIMA</span>
    <span class="row-subtitle">Formatos de representación en la arquitectura chilena</span>
  </div>
  <div class="mobile-middle">
    <div class="mobile-video">
      <video
        class="hero-video"
        autoplay
        muted
        playsinline
        loop
        preload="auto"
        onloadeddata="this.classList.add('is-ready')"
      >
        <source src={videoSrc} type="video/mp4">
      </video>
    </div>
  </div>
  <div class="mobile-bottom">
    <span class="row-left">primapress</span>
    <img class="row-logo" src={mincapLogo.src} alt="Mincap logo" />
  </div>
</div>

<style>
  .video-mobile {
    width: 100%;
    height: 100svh;
    min-height: 100svh;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: calc(2.5vh + env(safe-area-inset-top, 0px)) 6vw calc(2.5vh + env(safe-area-inset-bottom, 0px));
    box-sizing: border-box;
    position: relative;
    gap: 24px;
    overflow: hidden;
  }

  .mobile-top {
    width: 100%;
    text-align: center;
    color: #fff;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    flex: 0 0 auto;
  }

  .row-title {
    font-size: 1.05rem;
    letter-spacing: 0.14em;
  }

  .mobile-middle {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    align-self: center;
    flex: 1 1 auto;
    min-height: 0;
  }

  .row-subtitle {
    width: 100%;
    color: #fff;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    line-height: 1.3;
    text-align: center;
  }

  .mobile-video {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    flex: 1 1 auto;
    min-height: 0;
    height: 100%;
  }

  .hero-video {
    width: 100%;
    height: auto;
    max-height: 100%;
    display: block;
    object-fit: contain;
    opacity: 0;
    transition: opacity 240ms ease-out;
    background: #000;
  }

  .hero-video.is-ready {
    opacity: 1;
  }

  .mobile-bottom {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: #fff;
    letter-spacing: 0.08em;
    flex: 0 0 auto;
  }

  .row-left {
    white-space: nowrap;
    font-size: 0.82rem;
  }

  .row-logo {
    height: 52px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  @media (max-width: 900px) {
    .video-mobile {
      display: flex;
    }
  }
</style>
