---
import videoSrc from "../assets/video.mp4";
import mincapLogo from "../assets/mincap_logo.png";
---
<div class="video-mobile">
  <div class="mobile-top">
    <span class="row-center">Formatos de representación en la arquitectura chilena</span>
  </div>
  <div class="mobile-video">
    <video
      class="hero-video"
      autoplay
      muted
      playsinline
      loop
      preload="auto"
      onloadeddata="this.classList.add('is-ready')"
    >
      <source src={videoSrc} type="video/mp4">
    </video>
  </div>
  <div class="mobile-bottom">
    <span class="row-left">PRIMA</span>
    <img class="row-logo" src={mincapLogo.src} alt="Mincap logo" />
  </div>
</div>

<style>
  .video-mobile {
    width: 100%;
    height: 100vh;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: 4vh 4vw 8vh;
    box-sizing: border-box;
    position: relative;
    gap: 16px;
    overflow: hidden;
  }

  .mobile-top {
    width: 100%;
    text-align: center;
    color: #fff;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    line-height: 1.3;
  }

  .mobile-video {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    flex: 1 1 auto;
    min-height: 0;
  }

  .hero-video {
    width: 100%;
    height: auto;
    max-height: 60vh;
    display: block;
    object-fit: contain;
    opacity: 0;
    transition: opacity 240ms ease-out;
    background: #000;
  }

  .hero-video.is-ready {
    opacity: 1;
  }

  .mobile-bottom {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: #fff;
    letter-spacing: 0.08em;
    margin-top: auto;
  }

  .row-left {
    white-space: nowrap;
    font-size: 0.9rem;
  }

  .row-logo {
    height: 64px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  @media (max-width: 900px) {
    .video-mobile {
      display: flex;
    }
  }
</style>
